generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  user_id       Int        @id @default(autoincrement())
  full_name     String
  email         String     @unique
  password_hash String
  role          UserType   @default(volunteer)
  status        UserStatus @default(active)
  created_at    DateTime   @default(now())
  updated_at    DateTime   @updatedAt

  profile       VolunteerProfile?
  applications  Application[]
  opportunities Opportunity[]      @relation("PostedBy")
  memberships   OrgMember[]
  saved         SavedOpportunity[]

  organization Organization?
}

model VolunteerProfile {
  profile_id Int @id @default(autoincrement())
  user_id    Int @unique

  phone_num       String?
  bio             String?
  gender          String?
  location        String?
  date_of_birth   DateTime?
  profile_picture String?

  user User @relation(fields: [user_id], references: [user_id])
}

model Organization {
  org_id Int @id @default(autoincrement())

  name          String
  description   String?
  website       String?
  logo          String?
  location      String?
  contact_email String?
  contact_phone String?
  status        OrgStatus @default(pending)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  owner_id Int  @unique
  owner    User @relation(fields: [owner_id], references: [user_id])

  opportunities Opportunity[]
  members       OrgMember[]
}

model OrgMember {
  user_id Int
  org_id  Int

  role_in_org String
  joined_at   DateTime @default(now())

  user         User         @relation(fields: [user_id], references: [user_id])
  organization Organization @relation(fields: [org_id], references: [org_id])

  @@id([user_id, org_id])
}

model Category {
  category_id   Int     @id @default(autoincrement())
  category_name String  @unique
  description   String?

  opportunities Opportunity[]
}

model Opportunity {
  opp_id      Int       @id @default(autoincrement())
  org_id      Int
  posted_by   Int
  category_id Int
  title       String
  description String
  requirement String
  benefits    String?
  location    String
  format      OppFormat
  work_time   String
  start_date  DateTime
  end_date    DateTime
  image       String?
  status      OppStatus @default(draft)
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt

  organization Organization       @relation(fields: [org_id], references: [org_id])
  poster       User               @relation("PostedBy", fields: [posted_by], references: [user_id])
  category     Category           @relation(fields: [category_id], references: [category_id])
  applications Application[]
  skills       OpportunitySkill[]
  saved        SavedOpportunity[]
}

model Application {
  application_id Int               @id @default(autoincrement())
  user_id        Int
  opp_id         Int
  status         ApplicationStatus @default(pending)
  applied_at     DateTime          @default(now())
  updated_at     DateTime          @updatedAt
  user           User              @relation(fields: [user_id], references: [user_id])
  opportunity    Opportunity       @relation(fields: [opp_id], references: [opp_id])

  @@unique([user_id, opp_id])
}

model Skill {
  skill_id   Int    @id @default(autoincrement())
  skill_name String @unique

  opportunities OpportunitySkill[]
}

model OpportunitySkill {
  opp_id      Int
  skill_id    Int
  opportunity Opportunity @relation(fields: [opp_id], references: [opp_id])
  skill       Skill       @relation(fields: [skill_id], references: [skill_id])

  @@id([opp_id, skill_id])
}

model SavedOpportunity {
  user_id     Int
  opp_id      Int
  saved_at    DateTime    @default(now())
  user        User        @relation(fields: [user_id], references: [user_id])
  opportunity Opportunity @relation(fields: [opp_id], references: [opp_id])

  @@id([user_id, opp_id])
}

enum UserType {
  volunteer
  organization
  admin
}

enum UserStatus {
  active
  inactive
  banned
}

enum OrgStatus {
  pending
  approved
  rejected
}

enum OppFormat {
  online
  onsite
  hybrid
}

enum OppStatus {
  open
  closed
  draft
}

enum ApplicationStatus {
  pending
  accepted
  rejected
  cancelled
}
